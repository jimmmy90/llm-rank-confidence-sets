# Copy to .env and fill in your OpenRouter key:
#
#   cp .env.example .env
#
# Get a key at https://openrouter.ai/keys — one key serves every model in
# models.yaml (no per-provider keys needed).

OPENROUTER_API_KEY=

# --- Optional ---
# The benchmarks (MMLU-Pro, GPQA-Diamond) load from public sources, so NO
# HuggingFace token is required. HF_TOKEN only matters if you swap in a gated
# dataset.
# HF_TOKEN=
